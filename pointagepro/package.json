{
  "name": "pointagepro",
  "version": "1.0.0",
  "description": "Application de pointage QR Code - Offline First PWA",
  "main": "electron.js",
  "scripts": {
    "start": "npx serve .",
    "electron": "electron electron.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.pointagepro.app",
    "productName": "PointagePro",
    "win": { "target": "nsis", "icon": "icon.ico" },
    "mac": { "target": "dmg", "icon": "icon.icns" },
    "linux": { "target": "AppImage" },
    "files": ["index.html", "manifest.json", "sw.js", "*.js", "*.css"]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "keywords": ["pointage", "qrcode", "pwa", "offline", "rh"],
  "author": "PointagePro Team",
  "license": "MIT"
}
